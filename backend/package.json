{
    "name": "theatrex-backend",
    "version": "1.0.0",
    "description": "TheatreX Backend API - Operating Theatre Management System",
    "main": "server.js",
    "type": "module",
    "scripts": {
        "start": "node server.js",
        "dev": "nodemon server.js",
        "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
        "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
        "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage"
    },
    "keywords": [
        "theatre",
        "management",
        "hospital",
        "surgery"
    ],
    "author": "TheatreX Team",
    "license": "ISC",
    "dependencies": {
        "@clerk/clerk-sdk-node": "^4.13.23",
        "@google/generative-ai": "^0.24.1",
        "@prisma/adapter-pg": "^7.4.0",
        "@prisma/client": "^7.4.0",
        "bcrypt": "^6.0.0",
        "bcryptjs": "^2.4.3",
        "cors": "^2.8.5",
        "dotenv": "^16.6.1",
        "express": "^4.18.2",
        "jsonwebtoken": "^9.0.2",
        "multer": "^2.1.1",
        "node-cron": "^4.2.1",
        "pg": "^8.18.0",
        "prisma": "^7.4.0",
        "resend": "^6.9.1",
        "svix": "^1.87.0"
    },
    "devDependencies": {
        "jest": "^29.7.0",
        "nodemon": "^3.0.2",
        "supertest": "^7.2.2"
    },
    "jest": {
        "testEnvironment": "node",
        "coveragePathIgnorePatterns": [
            "/node_modules/"
        ],
        "testMatch": [
            "**/tests/**/*.test.js"
        ],
        "transform": {}
    }
}
