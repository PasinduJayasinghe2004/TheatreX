# Server Configuration
PORT=5000
NODE_ENV=development

# PostgreSQL Database Configuration (Neon Cloud)
# Get the actual DATABASE_URL from team lead
DATABASE_URL=postgresql://username:password@host.neon.tech/neondb?sslmode=require&channel_binding=require

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=your-refresh-token-secret-key
JWT_REFRESH_EXPIRE=30d

# Resend Email Configuration
# Get the actual RESEND_API_KEY from team lead
RESEND_API_KEY=re_your-resend-api-key-here
CLIENT_URL=http://localhost:5173
